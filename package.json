{
  "name": "lga",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n API,WEB -c blue,green \"npm run dev --workspace=api\" \"npm run dev --workspace=web\"",
    "dev:api": "npm run dev --workspace=api",
    "dev:web": "npm run dev --workspace=web"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
